---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { COMPANY_LEGAL_NAME, COMPANY_NUMBER, EMAIL, ADDRESS } from '../consts';
---

<!-- TODO(owner): have this policy reviewed before launch — it's a sound UK GDPR
     starting point but only you know exactly what you collect (analytics, form
     provider, cookies). -->

<BaseLayout
  title="Privacy Policy | Cumulus Digital"
  description="How Cumulus Digital Limited collects, uses and protects your personal data."
>
  <PageHero eyebrow="Legal" lede="How we collect, use and protect your personal data.">
    Privacy <em class="glow">policy</em>.
  </PageHero>

  <section class="section">
    <div class="container">
      <div class="prose">
        <p>
          This policy explains how {COMPANY_LEGAL_NAME} ("we", "us") collects and uses
          personal data when you use this website or contact us. We are registered in
          England &amp; Wales (company no. {COMPANY_NUMBER}) at {ADDRESS.street},
          {ADDRESS.locality}, {ADDRESS.region} {ADDRESS.postcode}, and we are the data
          controller for the purposes of UK data protection law (UK GDPR and the Data
          Protection Act 2018).
        </p>

        <h2>What we collect</h2>
        <ul>
          <li><strong>Contact details you give us</strong> — name, email address, phone number and anything you include in a message or enquiry form.</li>
          <li><strong>Technical data</strong> — standard server logs such as IP address, browser type and pages visited, used to keep the site secure and working.</li>
        </ul>

        <h2>How we use it</h2>
        <ul>
          <li>To respond to your enquiry and provide our services (legitimate interest / steps prior to a contract).</li>
          <li>To administer and secure this website (legitimate interest).</li>
          <li>We do <strong>not</strong> sell your data or use it for third-party advertising.</li>
        </ul>

        <h2>Who we share it with</h2>
        <p>
          Trusted service providers who help us run the website and handle enquiries
          (for example our hosting provider and form-processing service), under
          appropriate data-processing terms. We never share your details for marketing.
        </p>

        <h2>How long we keep it</h2>
        <p>
          Enquiry correspondence is kept for as long as needed to deal with your
          enquiry and any follow-up, then deleted. Client records are kept for the
          duration of our engagement and as required by law (for example, accounting
          records).
        </p>

        <h2>Your rights</h2>
        <p>
          You have the right to access, correct, delete or restrict the use of your
          personal data, and to object to processing. To exercise any of these rights,
          email us at <a href={`mailto:${EMAIL}`}>{EMAIL}</a>. You also have the right
          to complain to the Information Commissioner's Office at
          <a href="https://ico.org.uk" rel="noopener">ico.org.uk</a>.
        </p>

        <h2>Changes to this policy</h2>
        <p>
          We may update this policy from time to time. The latest version will always
          be published on this page.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
