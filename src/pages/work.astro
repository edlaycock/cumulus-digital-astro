---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const work = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Our Work — Web Design & Digital Projects | Cumulus Digital"
  description="Selected projects by Cumulus Digital: bespoke websites, branding and digital marketing for Surrey businesses and travel brands."
>
  <PageHero
    eyebrow="Our work"
    lede="We're rebuilding our portfolio for the new site. Here's a project that's live today — with room for yours next to it."
  >
    Ideas made <em class="glow">real</em>.
  </PageHero>

  <section class="section work-section">
    <div class="container">
      <ul class="work-grid" role="list">
        {work.map((item) => (
          <li class={`work-card${item.data.wide ? ' work-card--wide' : ''}${item.data.placeholder ? ' work-card--placeholder' : ''}`}>
            <div class="work-card-inner">
              <div class="work-card-visual" aria-hidden="true"></div>
              <span class="work-card-monogram" aria-hidden="true">
                {item.data.client.split(' ').map((w) => w[0]).slice(0, 3).join('')}
              </span>
              <div class="work-card-overlay"></div>
              <div class="work-card-content">
                <span class="work-tag">{item.data.services.join(' + ')}</span>
                <h3>{item.data.title}</h3>
                <p>{item.data.summary}</p>
                {item.data.url && (
                  <a class="btn btn--ghost" href={item.data.url} target="_blank" rel="noopener">
                    Visit the site →
                  </a>
                )}
                {item.data.placeholder && (
                  <a class="btn btn--ghost" href="/contact/">Start something like this →</a>
                )}
              </div>
            </div>
          </li>
        ))}
      </ul>

      <div class="work-cta">
        <a class="btn btn--primary btn--lg" href="/contact/">Discuss your project →</a>
      </div>
    </div>
  </section>
</BaseLayout>
