---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Cumulus Digital"
  description="Sorry, that page doesn't exist. Head back to the Cumulus Digital homepage."
>
  <section class="notfound">
    <div>
      <p class="notfound-code" aria-hidden="true">404</p>
      <h1>This page has drifted off.</h1>
      <p>The page you're looking for doesn't exist — it may have moved in our site rebuild.</p>
      <a class="btn btn--primary btn--lg" href="/">Back to the homepage →</a>
    </div>
  </section>
</BaseLayout>
