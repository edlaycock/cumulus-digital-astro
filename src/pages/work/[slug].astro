---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import WorkPreview from '../../components/WorkPreview.astro';

export async function getStaticPaths() {
  const work = await getCollection('work');
  return work.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const initials = d.client.split(' ').map((w) => w[0]).slice(0, 3).join('');
const hasStructured = Boolean(d.challenge || d.approach || d.result);
---

<BaseLayout
  title={`${d.client} — Case Study | Cumulus Digital`}
  description={d.summary}
>
  <PageHero eyebrow={`Case study · ${d.client}`}>
    {d.title}
  </PageHero>

  <section class="casestudy-preview-section">
    <div class="container">
      <div class="casestudy-preview" data-reveal>
        <WorkPreview client={d.client} url={d.url} image={d.image} eager />
      </div>
    </div>
  </section>

  <section class="section casestudy-body">
    <div class="container casestudy">
      <div class="casestudy-main">
        <ul class="casestudy-tags" role="list">
          {d.services.map((s) => <li class="work-tag">{s}</li>)}
        </ul>

        {hasStructured ? (
          <div class="casestudy-sections">
            <p class="casestudy-lede">{d.summary}</p>
            {d.challenge && (
              <div class="casestudy-block"><h2>The challenge</h2><p>{d.challenge}</p></div>
            )}
            {d.approach && (
              <div class="casestudy-block"><h2>What we did</h2><p>{d.approach}</p></div>
            )}
            {d.result && (
              <div class="casestudy-block"><h2>The result</h2><p>{d.result}</p></div>
            )}
          </div>
        ) : (
          <div class="prose"><Content /></div>
        )}

        {d.metrics && d.metrics.length > 0 && (
          <ul class="casestudy-metrics" role="list">
            {d.metrics.map((m) => (
              <li>
                <strong>{m.value}</strong>
                <span>{m.label}</span>
              </li>
            ))}
          </ul>
        )}

        <div class="casestudy-actions">
          {d.url && (
            <a class="btn btn--outline btn--lg" href={d.url} target="_blank" rel="noopener">
              Visit the live site →
            </a>
          )}
          <a class="btn btn--primary btn--lg" href="/contact/" data-magnetic>Start a project like this →</a>
        </div>
        <a class="casestudy-back" href="/work/">← Back to all work</a>
      </div>

      <aside class="casestudy-aside">
        <div class="casestudy-card">
          <div class="casestudy-monogram" aria-hidden="true">{initials}</div>
          <dl>
            <dt>Client</dt>
            <dd>{d.client}</dd>
            <dt>What we did</dt>
            <dd>{d.services.join(', ')}</dd>
            {d.url && (
              <>
                <dt>Live site</dt>
                <dd><a href={d.url} target="_blank" rel="noopener">{d.url.replace(/^https?:\/\//, '').replace(/\/$/, '')}</a></dd>
              </>
            )}
          </dl>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
