---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCards from '../components/ServiceCards';
import TestimonialCarousel from '../components/TestimonialCarousel';
---

<BaseLayout
  title="Cumulus Digital — Digital Marketing & Web Design, Surrey"
  description="Bespoke branding, hand-built websites and SEO for ambitious UK businesses. 25+ years travel industry experience. Based in Hersham, Walton-on-Thames, Surrey."
>
<!-- ===================== HERO ===================== -->
    <section class="hero" id="home">
      <canvas id="hero-canvas" aria-hidden="true"></canvas>
      <div class="hero-scrim" aria-hidden="true"></div>

      <div class="hero-body">
        <div class="hero-copy">
          <p class="eyebrow reveal d1">
            <span class="eyebrow-dot"></span>
            Digital marketing &amp; web · Surrey, UK
          </p>

          <h1 class="headline reveal d2">
            It's about making<br />
            ideas <em class="glow">happen</em>.
          </h1>

          <p class="lede reveal d3">
            Bespoke branding, fast hand-built websites and search marketing
            for ambitious UK businesses — backed by 25&nbsp;years in the
            travel sector. Most clients see real impact within weeks.
          </p>

          <div class="cta-row reveal d4">
            <a class="btn btn--primary btn--lg" href="#contact">Start a project →</a>
            <a class="btn btn--ghost btn--lg" href="#work">See our work</a>
          </div>

          <ul class="trust reveal d5" aria-label="Trust signals">
            <li><span class="tick" aria-hidden="true">✦</span> Google Partner</li>
            <li><span class="tick" aria-hidden="true">✦</span> 25+ yrs travel specialists</li>
            <li><span class="tick" aria-hidden="true">✦</span> Walton-on-Thames, Surrey</li>
          </ul>
        </div>
      </div>

      <div class="hero-scroll-hint reveal d5" aria-hidden="true">
        <span class="scroll-line"></span>
        <span class="scroll-label">scroll</span>
      </div>
    </section>

    <!-- ===================== CLIENT LOGOS ===================== -->
    <section class="logos-band" aria-label="Clients we've worked with">
      <div class="container">
        <p class="logos-label">Trusted by ambitious brands</p>
        <ul class="logos-row" role="list">
          <li><span class="logo-placeholder">OakBridge Group</span></li>
          <li><span class="logo-placeholder">PSD Solutions</span></li>
          <li><span class="logo-placeholder">Heritage Tours</span></li>
          <li><span class="logo-placeholder">Surrey Ventures</span></li>
          <li><span class="logo-placeholder">TravelCo</span></li>
          <li><span class="logo-placeholder">Apex Media</span></li>
        </ul>
      </div>
    </section>

    <!-- ===================== SERVICES ===================== -->
    <section class="section services-section" id="services">
      <div class="container">
        <div class="section-header">
          <p class="section-label">What we do</p>
          <h2 class="section-title">
            Everything you need<br />to grow online.
          </h2>
          <p class="section-sub">
            From first impression to lasting impact — strategy, design, code,
            and marketing that works together seamlessly.
          </p>
        </div>

        <ServiceCards client:visible />
      </div>
    </section>

    <!-- ===================== NUMBERS BAND ===================== -->
    <section class="numbers-band">
      <video
        class="numbers-video"
        autoplay
        muted
        loop
        playsinline
        aria-hidden="true"
      >
        <source src="/numbers-band.webm" type="video/webm" />
      </video>
      <div class="numbers-content">
        <div class="container">
          <ul class="numbers-row" role="list">
            <li>
              <strong class="number-val">25<span>+</span></strong>
              <span class="number-label">Years travel experience</span>
            </li>
            <li>
              <strong class="number-val">100<span>+</span></strong>
              <span class="number-label">Brands launched</span>
            </li>
            <li>
              <strong class="number-val">Weeks</strong>
              <span class="number-label">Typical time to impact</span>
            </li>
            <li>
              <strong class="number-val">Surrey</strong>
              <span class="number-label">Based in Walton-on-Thames</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ===================== VALUES ===================== -->
    <section class="section values-section">
      <div class="container">
        <div class="section-header">
          <p class="section-label">How we work</p>
          <h2 class="section-title">Our principles.</h2>
          <p class="section-sub">Four things we believe that shape everything we do.</p>
        </div>
        <div class="values-grid">
          <div class="value-card">
            <span class="value-num">01</span>
            <h3>We build, not bolt together</h3>
            <p>Custom code, not plugin stacks. Every site we build is hand-crafted for speed, security and longevity — so you never outgrow it.</p>
          </div>
          <div class="value-card">
            <span class="value-num">02</span>
            <h3>We know your industry</h3>
            <p>25+ years inside the travel sector means we ask smarter questions and skip the expensive learning curve most agencies charge you for.</p>
          </div>
          <div class="value-card">
            <span class="value-num">03</span>
            <h3>We move fast</h3>
            <p>Most clients see measurable impact within weeks, not quarters. We're built for momentum — not endless rounds of revisions and bureaucracy.</p>
          </div>
          <div class="value-card">
            <span class="value-num">04</span>
            <h3>We stay partners</h3>
            <p>We don't disappear post-launch. We're on hand for ongoing growth, iteration and support — because your success is how we measure ours.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== WORK ===================== -->
    <section class="section work-section" id="work">
      <div class="container">
        <div class="section-header">
          <p class="section-label">Our work</p>
          <h2 class="section-title">Ideas made real.</h2>
          <p class="section-sub">
            A selection of projects we're proud of — each one built to solve
            a specific business problem and deliver measurable results.
          </p>
        </div>

        <ul class="work-grid" role="list">

          <li class="work-card work-card--wide">
            <div class="work-card-inner">
              <img
                class="work-card-photo"
                src="https://images.unsplash.com/photo-1467232004584-a241de8b1d1f?w=1200&auto=format&fit=crop&q=75"
                alt="Bespoke website on laptop"
                loading="lazy"
              />
              <div class="work-card-overlay"></div>
              <div class="work-card-content">
                <span class="work-tag">Branding + Web</span>
                <h3>Full brand refresh &amp; bespoke build</h3>
                <p>End-to-end identity and website for a Surrey professional services firm — from strategy through to launch.</p>
                <a class="btn btn--ghost" href="#contact">Enquire about this →</a>
              </div>
            </div>
          </li>

          <li class="work-card">
            <div class="work-card-inner">
              <img
                class="work-card-photo"
                src="https://images.unsplash.com/photo-1432888498266-38ffec3eaf0a?w=800&auto=format&fit=crop&q=75"
                alt="SEO analytics results"
                loading="lazy"
              />
              <div class="work-card-overlay"></div>
              <div class="work-card-content">
                <span class="work-tag">SEO</span>
                <h3>Organic traffic +340%</h3>
                <p>Sustained SEO programme that tripled organic search visibility for a travel operator within six months.</p>
              </div>
            </div>
          </li>

          <li class="work-card">
            <div class="work-card-inner">
              <img
                class="work-card-photo"
                src="https://images.unsplash.com/photo-1488085061387-422e29b40080?w=800&auto=format&fit=crop&q=75"
                alt="Digital transformation travel brand"
                loading="lazy"
              />
              <div class="work-card-overlay"></div>
              <div class="work-card-content">
                <span class="work-tag">Strategy + Digital Marketing</span>
                <h3>Digital transformation for a heritage travel brand</h3>
                <p>Advisory and execution across web, SEO, and paid channels — moving a traditional business online.</p>
              </div>
            </div>
          </li>

          <li class="work-card work-card--wide">
            <div class="work-card-inner">
              <img
                class="work-card-photo"
                src="https://images.unsplash.com/photo-1581291518857-4f2be5d6b28f?w=1200&auto=format&fit=crop&q=75"
                alt="Custom web platform on multiple devices"
                loading="lazy"
              />
              <div class="work-card-overlay"></div>
              <div class="work-card-content">
                <span class="work-tag">Web Development</span>
                <h3>Custom web platform for a professional membership body</h3>
                <p>Secure, fast, accessible — hand-built to spec, not stretched from a template.</p>
                <a class="btn btn--ghost" href="#contact">Start something similar →</a>
              </div>
            </div>
          </li>
        </ul>

        <div class="work-cta">
          <a class="btn btn--primary btn--lg" href="#contact">Discuss your project →</a>
        </div>
      </div>
    </section>

    <!-- ===================== TRAVEL SPECIALISM ===================== -->
    <section class="section travel-section" id="about">
      <div class="container travel-inner">
        <div class="travel-copy">
          <p class="section-label">25+ years in travel</p>
          <h2 class="section-title">
            We know your<br />industry from the inside.
          </h2>
          <p class="travel-body">
            Most digital agencies learn your sector from a brief. We've spent over
            two decades working inside the travel industry — with operators, agents,
            and destination brands. That means we ask better questions, spot the right
            opportunities, and skip the expensive learning curve.
          </p>
          <ul class="travel-checklist">
            <li>Tour operators &amp; travel agents</li>
            <li>Destination marketing &amp; DMOs</li>
            <li>Hospitality &amp; accommodation brands</li>
            <li>Travel technology companies</li>
          </ul>
          <a class="btn btn--primary" href="#contact">Talk to a travel specialist →</a>
        </div>

        <div class="travel-photo-wrap">
          <img
            src="https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=900&auto=format&fit=crop&q=80"
            alt="Travel landscape — planes and destinations"
            loading="lazy"
          />
          <div class="travel-photo-badge">
            <strong>25+</strong>
            <span>Years in travel</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== SURREY GEO ===================== -->
    <section class="section surrey-section">
      <div class="container surrey-inner">
        <div class="surrey-photo-wrap">
          <img
            src="https://images.unsplash.com/photo-1533929736458-ca588d08c8be?w=900&auto=format&fit=crop&q=80"
            alt="Surrey and surrounding areas"
            loading="lazy"
          />
        </div>

        <div class="surrey-copy">
          <p class="section-label">Local to Surrey</p>
          <h2 class="section-title">
            Your local digital<br />agency in Surrey.
          </h2>
          <p class="travel-body">
            Based in Walton-on-Thames, we serve ambitious businesses across Surrey
            and the South East. We know the local market, the competition, and the
            opportunities — and we bring national-agency quality to your doorstep.
          </p>
          <div class="surrey-areas">
            <span class="surrey-tag">Walton-on-Thames</span>
            <span class="surrey-tag">Guildford</span>
            <span class="surrey-tag">Weybridge</span>
            <span class="surrey-tag">Woking</span>
            <span class="surrey-tag">Epsom</span>
            <span class="surrey-tag">Kingston</span>
            <span class="surrey-tag">Reigate</span>
            <span class="surrey-tag">London</span>
          </div>
          <a class="btn btn--primary" href="#contact">Get a free consultation →</a>
        </div>
      </div>
    </section>

    <!-- ===================== TESTIMONIALS ===================== -->
    <section class="section testimonials-section">
      <div class="container">
        <div class="section-header">
          <p class="section-label">What clients say</p>
          <h2 class="section-title">Results speak first.</h2>
          <p class="section-sub">
            We measure success by what our clients achieve — not just what we deliver.
          </p>
        </div>
        <TestimonialCarousel client:visible />
      </div>
    </section>

    <!-- ===================== CTA ===================== -->
    <section class="cta-section" id="contact">
      <div class="container">
        <div class="cta-inner">
          <div class="cta-glow" aria-hidden="true"></div>
          <p class="section-label">Ready to start?</p>
          <h2 class="cta-headline">
            Let's make your<br />idea <em class="glow">happen</em>.
          </h2>
          <p class="cta-sub">
            Tell us about your project — we'll come back within one working day.
          </p>
          <div class="cta-actions">
            <a class="btn btn--primary btn--lg" href="mailto:hello@cumulusdigital.co.uk">
              Email us directly →
            </a>
            <a class="btn btn--ghost btn--lg" href="tel:02080504754">
              020 8050 4754
            </a>
          </div>
          <p class="cta-location">
            Burwood Road, Hersham, Walton-on-Thames, Surrey KT12 4AG
          </p>
        </div>
      </div>
    </section>

  <script>
    import '../scripts/hero.js';
  </script>
</BaseLayout>
