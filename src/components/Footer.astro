---
import {
  SITE_TAGLINE,
  EMAIL,
  PHONE_DISPLAY,
  PHONE_TEL,
  ADDRESS,
  COMPANY_LEGAL_NAME,
  COMPANY_NUMBER,
} from '../consts';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a class="brand" href="/" aria-label="Cumulus Digital home">
        <img class="brand-logo" src="/cumulus-logo.png" alt="Cumulus Digital" loading="lazy" />
      </a>
      <p class="footer-tagline">{SITE_TAGLINE}</p>
    </div>

    <nav class="footer-nav" aria-label="Footer">
      <div class="footer-col">
        <h4>Services</h4>
        <a href="/services/#branding">Branding</a>
        <a href="/services/#web-design">Web Design</a>
        <a href="/services/#web-development">Web Development</a>
        <a href="/services/#digital-marketing">Digital Marketing</a>
        <a href="/services/#strategy">Strategy &amp; Consulting</a>
        <a href="/about/#travel">Travel Industry</a>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <a href="/about/">About Us</a>
        <a href="/work/">Our Work</a>
        <a href="/contact/">Contact</a>
      </div>
      <div class="footer-col">
        <h4>Contact</h4>
        <a href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a>
        <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
        <p class="footer-address">
          {ADDRESS.street}<br />
          {ADDRESS.locality}<br />
          {ADDRESS.region} {ADDRESS.postcode}
        </p>
      </div>
    </nav>
  </div>

  <div class="footer-base">
    <div class="container footer-base-inner">
      <p>
        &copy; {year} {COMPANY_LEGAL_NAME}. Registered in England &amp; Wales, company no. {COMPANY_NUMBER}.
      </p>
      <div class="footer-legal">
        <a href="/privacy/">Privacy Policy</a>
        <a href="/terms/">Terms of Use</a>
      </div>
    </div>
  </div>
</footer>
