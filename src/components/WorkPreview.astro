---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  client: string;
  url?: string;
  image?: ImageMetadata;
  eager?: boolean;
}

const { client, url, image, eager = false } = Astro.props;
const initials = client.split(' ').map((w) => w[0]).slice(0, 3).join('');
const domain = url ? url.replace(/^https?:\/\//, '').replace(/\/$/, '') : null;
---

<div class="browser-frame">
  <div class="browser-bar" aria-hidden="true">
    <span class="browser-dots"><i></i><i></i><i></i></span>
    {domain && <span class="browser-url">{domain}</span>}
  </div>
  <div class="browser-body">
    {image ? (
      <Image
        class="browser-shot"
        src={image}
        alt={`${client} website`}
        widths={[480, 800, 1200]}
        sizes="(max-width: 720px) 100vw, 640px"
        loading={eager ? 'eager' : 'lazy'}
      />
    ) : (
      <div class="browser-placeholder">
        <span class="browser-monogram">{initials}</span>
      </div>
    )}
  </div>
</div>
